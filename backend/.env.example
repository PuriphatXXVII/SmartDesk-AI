# --- App ---
APP_ENV=development
APP_DEBUG=true
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=change-me-in-production-use-long-random-secret

# --- Database ---
DATABASE_URL=postgresql+psycopg://smartdesk:smartdesk_dev@localhost:5432/smartdesk

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- AI Providers ---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings — pick ONE provider (Voyage preferred). Leave all blank for the
# deterministic dev fallback (flow works, retrieval quality is poor).
# Voyage AI (recommended — multilingual, generous free tier): https://dash.voyageai.com
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5-lite
# OpenAI (alternative — requires paid credits): used at 1024 dims to match Voyage
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# --- Auth (Clerk) ---
# Leave these BLANK in local dev to enable the dev-auth bypass (synthetic dev user,
# no signup needed). Fill them in to verify real Clerk JWTs.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_ISSUER=
CLERK_JWKS_URL=
# From Clerk dashboard > Configure > Webhooks (after creating an endpoint)
CLERK_WEBHOOK_SECRET=

# --- CORS / Hosts (strict in production) ---
CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Observability ---
SENTRY_DSN=

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
WIDGET_RATE_LIMIT_PER_MINUTE=20

# --- Upload limits ---
MAX_UPLOAD_MB=25
