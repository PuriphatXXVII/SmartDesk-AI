# --- App ---
APP_ENV=development
APP_DEBUG=true
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=change-me-in-production-use-long-random-secret

# --- Database ---
DATABASE_URL=postgresql+psycopg://smartdesk:smartdesk_dev@localhost:5432/smartdesk

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- AI Providers ---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-xxx
EMBEDDING_MODEL=text-embedding-3-small

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# --- CORS / Hosts (strict in production) ---
CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Observability ---
SENTRY_DSN=

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
WIDGET_RATE_LIMIT_PER_MINUTE=20

# --- Upload limits ---
MAX_UPLOAD_MB=25
