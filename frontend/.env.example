NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Public origin of this frontend — used to build the widget embed snippet
# (<origin>/smartdesk.js). Set to the deployed URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: override the widget script URL outright (e.g. a dedicated CDN)
# NEXT_PUBLIC_WIDGET_SRC=

# Public widget key embedded on the landing page demo (leave blank = no widget shown)
NEXT_PUBLIC_DEMO_WIDGET_KEY=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
